# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=your_mongodb_connection_string

# JWT Configuration
JWT_SECRET=your_strong_jwt_secret_key_with_special_chars_1234567890!@#$%

# Client Configuration
# Use a comma-separated list if you need to allow more than one frontend origin.
CLIENT_URL=http://localhost:5173

# For Production:
# NODE_ENV=production
# CLIENT_URL=https://jobnest-personal-job-application-tracker.onrender.com
# Use strong, randomly generated JWT_SECRET
# Set MONGO_URI to production MongoDB connection string
